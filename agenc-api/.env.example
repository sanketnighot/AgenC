# Bridge (FastAPI) — copy to `.env` and fill values

# Emitter AXL HTTP API (already defaulted in code)
# EMITTER_API=http://127.0.0.1:8001

# Claim collection: window starts on first CLAIM; resolution runs after this many seconds
CLAIM_WINDOW_SEC=4

# If no CLAIM arrives within this many seconds of bounty POST → UNCLAIMED
NO_CLAIM_AFTER_BROADCAST_SEC=90

# Hard cap: bounty stuck in PENDING → UNCLAIMED
BOUNTY_PENDING_MAX_SEC=120

# If true: single claimant skips bridge LLM
ARBITER_SKIP_WHEN_UNANIMOUS=false
# When bridge LLM response is unusable, infer collaborate if task spans data + creative cues and ≥2 specialties claimed
ARBITER_HEURISTIC_COLLAB=true

# Bridge arbiter LLM
BRIDGE_LLM_PROVIDER=openai
BRIDGE_LLM_MODEL=gpt-4o-mini
BRIDGE_OPENAI_API_KEY=

# Optional overrides for Gemini / OpenRouter (otherwise workers’ keys are used):
# BRIDGE_GEMINI_API_KEY=   # defaults to GEMINI_API_KEY
# BRIDGE_OPENROUTER_API_KEY=   # defaults to OPENROUTER_API_KEY

# Worker LLM telemetry (POST /api/worker/telemetry → SSE worker_llm_delta for dashboard)
# Generate a random string; workers must set the same value as WORKER_TELEMETRY_SECRET.
BRIDGE_TELEMETRY_SECRET=
# Max UTF-8 bytes per POST delta (default 8192)
# MAX_TELEMETRY_DELTA=8192

# Copy the same secret into repo-root `.env` for workers (see worker1.py) as:
# WORKER_TELEMETRY_SECRET=
# Optional override (default http://127.0.0.1:8000/api/worker/telemetry)
# WORKER_TELEMETRY_BRIDGE_URL=
