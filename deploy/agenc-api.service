[Unit]
Description=AgenC API Bridge
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/axl/agenc-api
EnvironmentFile=/home/ubuntu/axl/.env
ExecStart=/home/ubuntu/.cargo/bin/uv run uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
