# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# ── MCP sidecars (integrations/: pip/uv install -e .) ────────────────────────
# Workers call tools via MCP_ROUTER_HTTP → POST …/route. Requires systemd units:
#   mcp-router (9003), agenc-mcp-web-search (9101), agenc-mcp-shared-memory (9102)
# See deploy/mcp-router.service and deploy/agenc-mcp-*.service
MCP_ROUTER_HTTP=http://127.0.0.1:9003

# ── Web search ────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-...

# ── Blockchain ────────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
CONTRACT_ADDRESS=0x...
ARBITER_PRIVATE_KEY=0x...
WORKER1_ETH_ADDRESS=0x...
WORKER2_ETH_ADDRESS=0x...
WORKER3_ETH_ADDRESS=0x...
WORKER4_ETH_ADDRESS=0x...

# ── AXL peer IDs (mesh "LIVE" in UI) ─────────────────────────────────────────
# The bridge matches these to the emitter's /topology peers. If you use new
# node key files on the server, set each to that worker AXL node's public key:
#   curl -s http://127.0.0.1:8002/topology | jq -r .our_public_key   # worker 1
#   curl -s http://127.0.0.1:8003/topology | jq -r .our_public_key   # worker 2
#   curl -s http://127.0.0.1:8004/topology | jq -r .our_public_key   # worker 3
#   curl -s http://127.0.0.1:8005/topology | jq -r .our_public_key   # worker 4
# Leave unset to use the peer IDs baked into agenc-api (dev defaults).
#WORKER1_PEER_ID=
#WORKER2_PEER_ID=
WORKER3_PEER_ID=
WORKER4_PEER_ID=

# ── Uniswap subgraph (free key at thegraph.com/studio) ───────────────────────
THEGRAPH_API_KEY=...

# ── Image generation (worker2) ────────────────────────────────────────────────
GEMINI_API_KEY=...
